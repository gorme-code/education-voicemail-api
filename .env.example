# ─── Salesforce Connected App (OAuth 2.0 client credentials flow) ───
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_INSTANCE_URL=https://scde--casemgmt.sandbox.my.salesforce.com
SF_API_VERSION=62.0

# Copy from Salesforce Setup → Queues → Education Voicemail → URL
SF_EDUCATION_QUEUE_ID=00GWA000007oHmP2AU

# Voicemail Case record type (as-built; Case create must set RecordTypeId)
SF_VOICEMAIL_RECORD_TYPE_ID=012WA000001OMMzYAO

# ─── API auth ───
# Shared secret used by MuleSoft (X-API-Key header)
API_KEY=

# development | production
API_ENV=development
